# Mahjong Soul paipu import.
# Account credentials are used locally by the mjsoul client to fetch paipu records.
MAJSOUL_ACCOUNT=
MAJSOUL_PASSWORD=
# Optional alternatives to account/password. Provide values manually only; do not
# scrape local client/browser storage in automated scripts.
MAJSOUL_ACCESS_TOKEN=
MAJSOUL_OAUTH2_UID=
MAJSOUL_OAUTH2_CODE=
MAJSOUL_OAUTH2_TYPE=
MAJSOUL_REGION=cn

# Optional. Mahjong Soul international server uses Yostar email-code login.
MAJSOUL_EN_YOSTAR_EMAIL=
MAJSOUL_EN_YOSTAR_UID=
MAJSOUL_EN_YOSTAR_TOKEN=
MAJSOUL_EN_YOSTAR_DEVICE_ID=

# Optional. Leave empty for the default mjsoul client behavior.
MAJSOUL_CLIENT_VERSION=

# Optional. Override the WebSocket gateway while debugging connection issues.
MAJSOUL_GATEWAY_URL=

# Optional. If empty, Mahjong Soul traffic is direct even when global proxy
# variables are set. Use direct/none/off to force no proxy.
MAJSOUL_PROXY_URL=
MAJSOUL_EN_PROXY_URL=

# Optional. Advanced login compatibility knobs; leave empty unless debugging login code 151.
MAJSOUL_RANDOM_KEY=
MAJSOUL_TAG=
MAJSOUL_CURRENCY_PLATFORMS=

# Optional. OpenAI-compatible LLM gateway for current-hand analysis chat.
# Keep real API keys in .env.local only. Never commit them.
ANALYSIS_LLM_BASE_URL=https://api.openai.com/v1
ANALYSIS_LLM_API_KEY=
ANALYSIS_LLM_MODEL=
ANALYSIS_LLM_TIMEOUT_MS=60000
ANALYSIS_LLM_MAX_TOKENS=900
ANALYSIS_LLM_FLASH_MODEL=
ANALYSIS_LLM_FLASH_TIMEOUT_MS=60000
ANALYSIS_LLM_FLASH_MAX_TOKENS=900
ANALYSIS_LLM_PRO_MODEL=
ANALYSIS_LLM_PRO_TIMEOUT_MS=180000
ANALYSIS_LLM_PRO_MAX_TOKENS=1200
ANALYSIS_LLM_RESPONSE_FORMAT=json_schema
# DeepSeek V4 enables thinking by default. Current-hand chat disables it unless set to enabled.
ANALYSIS_LLM_THINKING=disabled

# Optional. HTTP sidecar for Mortal or another professional mahjong engine.
# Leave ANALYSIS_ENABLE_ENGINE=false if you do not have a local engine.
ANALYSIS_ENABLE_ENGINE=false
MORTAL_ENGINE_URL=http://127.0.0.1:4010/analyze
MORTAL_ENGINE_TIMEOUT_MS=35000
MORTAL_SIDECAR_HOST=127.0.0.1
MORTAL_SIDECAR_PORT=4010
MORTAL_PROCESS_TIMEOUT_MS=30000
MORTAL_WORKER_TIMEOUT_MS=25000

# Optional. Python executable used by the Japanese mahjong scoring worker.
# Install Python dependencies with: python -m pip install -r requirements.txt
MAHJONG_SCORE_PYTHON=python

# One-process-per-request fallback. The sidecar replaces {actor} with seat 0-3.
MORTAL_COMMAND_TEMPLATE=

# Preferred local development mode. The worker should read JSON lines from stdin
# and write Mortal action JSON lines to stdout.
MORTAL_WORKER_COMMAND_TEMPLATE=

# Optional variables used by the included local Mortal adapter scripts.
# Do not vendor or publish model weights or third-party engine checkouts unless
# their licenses explicitly allow your intended distribution.
MAHJONG_COPILOT_DIR=
MORTAL_MODEL_FILE=
